# ============================================
# AI Live Room - API Server 环境配置模板
# 复制此文件为 .env 并填入实际值
# ============================================

# ---- 服务器配置 ----
PORT=3000
NODE_ENV=development

# ---- MySQL 数据库配置 ----
DB_HOST=127.0.0.1
DB_PORT=3309
DB_USER=root
DB_PASSWORD=root123
DB_NAME=chatroom_db

# ---- Redis 配置 ----
REDIS_HOST=127.0.0.1
REDIS_PORT=6379

# ---- 流媒体服务配置 ----
# 填写你的局域网IP或公网IP，用于生成推流/播放URL
STREAM_HOST=localhost
API_HOST=localhost

# ---- SRS 服务地址 ----
SRS_API_URL=http://localhost:1985/api/v1
SRS_RTC_SERVER=https://localhost:1985/rtc/v1/
